# Database (default: local PostgreSQL)
DATABASE_URL=postgresql://sanjeev@127.0.0.1/Textract

# Upload folder for raw and canonical files
UPLOAD_DIR=uploads

# Page screenshot DPI for PDFs and for Textract when rendering from PDF (default 300).
# Use at least 300 for good Textract quality; 400 recommended for code-heavy technical pages.
# SCREENSHOT_DPI=300

# --- AWS Textract (optional) ---
# Required for real PDF extraction via Textract. If unset, backend uses a placeholder.
# Use long-term IAM keys, or temporary credentials (e.g. from "aws login" or federation).
# For temporary credentials you must set AWS_SESSION_TOKEN as well.
# Textract must be enabled in the chosen region.
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
# Optional: required when using temporary credentials (ASIA... keys, aws login, get-federation-token)
# AWS_SESSION_TOKEN="your-session-token"
AWS_REGION=us-east-1
# Optional: S3 bucket for multi-page PDFs. Async Textract (StartDocumentTextDetection) requires
# the PDF to be in S3. If unset, multi-page PDFs get a mock message; single-page uses sync API.
# AWS_S3_BUCKET=your-textract-input-bucket
